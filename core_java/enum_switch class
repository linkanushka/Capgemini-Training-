enum Direction {
    NORTH, SOUTH, EAST, WEST
}

public class Main {
    public static void main(String[] args) {

        Direction d = Direction.EAST;

        switch(d) {
            case NORTH:
                System.out.println("Go Up");
                break;
            case SOUTH:
                System.out.println("Go Down");
                break;
            case EAST:
                System.out.println("Go Right");
                break;
            case WEST:
                System.out.println("Go Left");
                break;
        }
    }
}

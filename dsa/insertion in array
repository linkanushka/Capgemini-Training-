import java.util.*;

public class Main {
    public static void main(String[] args) {

        int[] arr = {1,2,3,4,5};
        int pos = 2;
        int val = 99;

        for(int i = arr.length-1; i > pos; i--) {
            arr[i] = arr[i-1];
        }

        arr[pos] = val;

        System.out.println(Arrays.toString(arr));
    }
}

import java.util.*;

public class Main {
    public static void main(String[] args) {

        int[] arr = {7,10,4,3,20,15};
        int k = 3;

        PriorityQueue<Integer> pq = new PriorityQueue<>();

        for(int num : arr){
            pq.add(num);

            if(pq.size() > k)
                pq.poll();
        }

        System.out.println("Kth largest = "+pq.peek());
    }
}

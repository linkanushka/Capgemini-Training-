import java.util.*;

public class Main {
    public static void main(String[] args) {
        int[] arr = {3, 8, 2, 10, 5};

        int max = arr[0];
        for(int i = 1; i < arr.length; i++) {
            if(arr[i] > max)
                max = arr[i];
        }

        System.out.println("Largest = " + max);
    }
}

class Engine {

    void start() {
        System.out.println("Engine starts");
    }
}

class Car {

    Engine e = new Engine();

    void drive() {
        e.start();
        System.out.println("Car moves");
    }
}

public class Main {
    public static void main(String[] args) {

        Car c = new Car();

        c.drive();
    }
}

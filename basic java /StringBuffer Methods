// 4. StringBuffer Methods
public class StringBufferExample2 {
    public static void main(String[] args) {
        StringBuffer sb = new StringBuffer("Hello");

        sb.append(" World");
        sb.insert(5, ",");
        sb.replace(0, 5, "Hi");
        sb.delete(2, 3);
        sb.reverse();

        System.out.println(sb);
    }
}

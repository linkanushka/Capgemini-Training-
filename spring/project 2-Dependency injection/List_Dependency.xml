<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="B1" class="DependencyInjection.Book">
        <property name="bookId" value="1"/>
        <property name="bookName" value="Wings of Fire"/>
    </bean>

    <bean id="B2" class="DependencyInjection.Book">
        <property name="bookId" value="2"/>
        <property name="bookName" value="Java Programming"/>
    </bean>

    <bean id="B3" class="DependencyInjection.Book">
        <property name="bookId" value="3"/>
        <property name="bookName" value="Spring Framework"/>
    </bean>

    <bean id="Lib1" class="DependencyInjection.library">
        <property name="id" value="201"/>
        <property name="name" value="Central Library"/>

        <property name="books">
            <list>
                <ref bean="B1"/>
                <ref bean="B2"/>
                <ref bean="B3"/>
            </list>
        </property>

    </bean>

</beans>
